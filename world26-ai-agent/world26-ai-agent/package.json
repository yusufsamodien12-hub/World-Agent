{
  "name": "world26-ai-agent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Standalone AI agent that plays world26-playground over HTTP. Swap this project out for a different AI project without touching the playground.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start:build": "node dist/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "tsx": "^4.19.2",
    "typescript": "~5.8.2"
  }
}
